@model IEnumerable<HotelUyutClean.Models.Booking>
@{
    ViewData["Title"] = "Все бронирования";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📋 Все бронирования</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Фото</th>
                    <th>ID</th>
                    <th>Клиент</th>
                    <th>Номер</th>
                    <th>Дата заезда</th>
                    <th>Дата выезда</th>
                    <th>Гостей</th>
                    <th>Стоимость</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td>
                            <img src="@booking.Room?.ImageUrl" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;" 
                                 onerror="this.src='https://via.placeholder.com/60'">
                        </td>
                        <td>@booking.Id</td>
                        <td>@booking.User?.Email</td>
                        <td>@booking.Room?.Title</td>
                        <td>@booking.CheckInDate.ToString("dd.MM.yyyy")</td>
                        <td>@booking.CheckOutDate.ToString("dd.MM.yyyy")</td>
                        <td>@booking.Guests</td>
                        <td>@booking.TotalPrice ₽</td>
                        <td>
                            @if (booking.Status == "Confirmed")
                            {
                                <span class="badge bg-success">Подтверждено</span>
                            }
                            else if (booking.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">Отменено</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">@booking.Status</span>
                            }
                         </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-sm btn-info">Детали</a>
                            <a asp-action="Edit" asp-route-id="@booking.Id" class="btn btn-sm btn-warning">Изменить</a>
                            <a asp-action="Delete" asp-route-id="@booking.Id" class="btn btn-sm btn-danger">Удалить</a>
                         </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>