@model IEnumerable<HotelUyutClean.Models.Room>
@{
    ViewData["Title"] = "Управление номерами";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🏨 Управление номерами (Админ-панель)</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Добавить номер
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Фото</th>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Площадь</th>
                    <th>Гостей</th>
                    <th>Доступен</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in Model)
                {
                    <tr>
                        <td>@room.Id</td>
                        <td>
                            <img src="@room.ImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;" 
                                 onerror="this.src='https://via.placeholder.com/50'">
                         </td>
                        <td>@room.Title</td>
                        <td>@room.Category</td>
                        <td>@room.Price ₽</td>
                        <td>@room.Area м²</td>
                        <td>@room.MaxGuests</td>
                        <td>
                            @if (room.IsAvailable)
                            {
                                <span class="badge bg-success">Доступен</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Недоступен</span>
                            }
                         </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-info">Просмотр</a>
                            <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-warning">Изменить</a>
                            <a asp-action="Delete" asp-route-id="@room.Id" class="btn btn-sm btn-danger">Удалить</a>
                         </td
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>