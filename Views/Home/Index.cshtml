@using HotelUyutClean.Models
@model HotelViewModel

@{
    ViewData["Title"] = "Главная - Гостиница Уют";
}

<!-- Hero секция -->
<div class="hero-section text-center text-white py-5" style="background: linear-gradient(135deg, #D4A373 0%, #8B6914 50%, #5C4033 100%);">
    <div class="container">
        <h1 class="display-4 fw-bold">@Model.HotelName</h1>
        <p class="lead fs-3">@Model.WelcomeMessage</p>
        <p class="fs-5 mt-3">🌟 4.8 ★★★★★ (245 отзывов) 🌟</p>
        <a href="/Home/Contacts" class="btn btn-light btn-lg mt-3">Забронировать сейчас</a>
    </div>
</div>

<!-- О нас вкратце -->
<div class="container my-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h2 class="mb-3">Добро пожаловать в "Уют"</h2>
            <p class="lead">Гостиница "Уют" - это не просто место для ночлега, это ваш дом вдали от дома.</p>
            <p>Расположенная в живописном районе города, наша гостиница предлагает комфортабельные номера, высокий уровень сервиса и тёплую, домашнюю атмосферу. Мы открылись в 2015 году и с тех пор приняли более 15 000 гостей из разных уголков мира.</p>
            <p>Каждый гость для нас особенный. Мы стремимся сделать ваш отдых незабываемым, предлагая индивидуальный подход и внимание к каждой детали.</p>
            <a href="/Home/About" class="btn btn-primary">Узнать больше о нас →</a>
        </div>
        <div class="col-md-6">
            <img src="/images/home/home1.jpg" class="img-fluid rounded shadow" alt="Отель Уют" onerror="this.src='https://via.placeholder.com/600x400?text=Наш+отель'">
        </div>
    </div>
</div>

<!-- Наши номера -->
<div class="container my-5">
    <h2 class="text-center mb-4">Наши номера</h2>
    <p class="text-center mb-5 fs-5">Выберите идеальный вариант для вашего отдыха</p>
    <div class="row">
        @if (Model.HomeImages != null)
        {
            foreach (var room in Model.HomeImages)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@room.ImagePath" class="card-img-top" alt="@room.Title" style="height: 250px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/400x250?text=Фото+не+загружено'">
                        <div class="card-body">
                            <h5 class="card-title">@room.Title</h5>
                            <p class="card-text">@room.Description</p>
                            <ul class="list-unstyled">
                                <li>✓ Бесплатный Wi-Fi</li>
                                <li>✓ Кондиционер</li>
                                <li>✓ Телевизор</li>
                                <li>✓ Ванная комната</li>
                            </ul>
                            <p class="price text-primary fw-bold fs-3">@room.Price ₽<span class="fs-6">/ночь</span></p>
                            <a href="/Home/Contacts" class="btn btn-primary w-100">Забронировать</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Наши преимущества -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">Почему выбирают нас?</h2>
        <div class="row text-center">
            <div class="col-md-3 mb-4">
                <div class="feature-box">
                    <i class="fas fa-wifi fa-3x mb-3" style="color: #8B6914;"></i>
                    <h5>Бесплатный Wi-Fi</h5>
                    <p>Высокоскоростной интернет на всей территории</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="feature-box">
                    <i class="fas fa-utensils fa-3x mb-3" style="color: #8B6914;"></i>
                    <h5>Завтрак включён</h5>
                    <p>Вкусный шведский стол каждое утро</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="feature-box">
                    <i class="fas fa-clock fa-3x mb-3" style="color: #8B6914;"></i>
                    <h5>Круглосуточная стойка</h5>
                    <p>Мы работаем 24/7 для вашего комфорта</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="feature-box">
                    <i class="fas fa-car fa-3x mb-3" style="color: #8B6914;"></i>
                    <h5>Бесплатная парковка</h5>
                    <p>Охраняемая парковка для гостей</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Отзывы гостей -->
<div class="container my-5">
    <h2 class="text-center mb-5">Что говорят наши гости</h2>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="mb-3 text-warning">★★★★★</div>
                    <p class="card-text">"Отличная гостиница! Очень чисто, уютно, персонал приветливый. Завтраки вкусные, расположение удобное. Обязательно вернусь сюда ещё!"</p>
                    <footer class="blockquote-footer">Анна Иванова</footer>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="mb-3 text-warning">★★★★★</div>
                    <p class="card-text">"Останавливаюсь здесь уже второй раз. Номера просторные, кровати удобные. Wi-Fi летает. Трансфер организовали отлично. Спасибо!"</p>
                    <footer class="blockquote-footer">Михаил Петров</footer>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="mb-3 text-warning">★★★★★</div>
                    <p class="card-text">"Прекрасное место для отдыха с семьёй. Детям понравилось, нам тоже. Рекомендую семейный номер - очень просторный и уютный."</p>
                    <footer class="blockquote-footer">Елена Сидорова</footer>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Спецпредложения -->
<div class="container my-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card bg-primary text-white h-100">
                <div class="card-body text-center p-5">
                    <h3>🏷️ Раннее бронирование</h3>
                    <p class="fs-4">Скидка 20%</p>
                    <p>При бронировании за 30 дней до заезда</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card bg-success text-white h-100">
                <div class="card-body text-center p-5">
                    <h3>👨‍👩‍👧‍👦 Семейный тариф</h3>
                    <p class="fs-4">Детям до 12 лет бесплатно</p>
                    <p>При размещении с родителями</p>
                </div>
            </div>
        </div>
    </div>
</div>